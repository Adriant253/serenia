# Base de datos (Google Cloud SQL)
DB_HOST=tu-ip-o-host-de-cloud-sql
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=serenia
DB_PORT=3306

# Google OAuth
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_CALLBACK_URL=https://tu-api.onrender.com/api/auth/google/callback

# Frontend (solo en Vercel, prefijo VITE_)
VITE_GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
VITE_API_URL=https://tu-api.onrender.com

# API en Render
FRONTEND_URL=https://tu-app.vercel.app

# Correo (recuperación de contraseña)
MAIL_USER=tu-correo@gmail.com
MAIL_PASS=tu-app-password-de-gmail
